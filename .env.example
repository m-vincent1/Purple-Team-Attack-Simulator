# Purple Team Attack Simulator — Environment Variables
# Copy this file to .env and adjust values

# Backend
DATABASE_URL=sqlite:///./purple_team.db
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Paths (relative to backend/)
SCENARIOS_DIR=scenarios
RULES_DIR=rules
GENERATED_LOGS_DIR=../generated_logs
GENERATED_REPORTS_DIR=../generated_reports
LAB_SANDBOX_DIR=../lab_sandbox

# Frontend
VITE_API_URL=http://localhost:8000
